    "steps": [
      {
        "number": 1,
        "instruction": "Butter, Staubzucker, Vanillezucker und Salz cremig rühren. Das Ei kurz einarbeiten."
      },
      {
        "number": 2,
        "instruction": "Mehl und Stärke mischen und nur so lange unterrühren, bis ein weicher Teig entsteht."
      },
      {
        "number": 3,
        "instruction": "Teig portionsweise durch den Fleischwolf mit Gebäckvorsatz drehen oder mit einem kräftigen Spritzsack aufs Blech setzen."
      },
      {
        "number": 4,
        "instruction": "Bei 180 °C etwa 10 bis 12 Minuten hell backen und vollständig abkühlen lassen."
      },
      {
        "number": 5,
        "instruction": "Kuvertüre schmelzen, Gebäckenden eintauchen und auf Backpapier fest werden lassen."
      }
    ],
    "tips": [
      "Wenn der Teig zu weich ist, 20 Minuten kühlen.",
      "Nicht dunkel backen; Spritzgebäck soll mürbe und hell bleiben."
